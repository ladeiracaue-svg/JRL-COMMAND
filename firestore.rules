rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    function isManager() {
      return isSignedIn() && getUserData().role == 'manager';
    }

    function isSeller() {
      return isSignedIn() && getUserData().role == 'seller';
    }

    function isUserActive() {
      return getUserData().active == true;
    }

    // Profiles
    match /users/{userId} {
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid == userId || (isManager() && resource.data.managerId == request.auth.uid));
      allow create: if isAdmin() || (isManager() && request.resource.data.role == 'seller' && request.resource.data.managerId == request.auth.uid);
      allow update: if isSignedIn() && (
        isAdmin() || 
        (request.auth.uid == userId && 
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'active', 'managerId', 'commissionRateDefault'])) ||
        (isManager() && resource.data.managerId == request.auth.uid && resource.data.role == 'seller')
      );
    }

    // Companies
    match /companies/{companyId} {
      allow read: if isSignedIn() && isUserActive() && (
        isAdmin() || 
        resource.data.responsibleUserId == request.auth.uid ||
        (isManager() && get(/databases/$(database)/documents/users/$(resource.data.responsibleUserId)).data.managerId == request.auth.uid)
      );
      allow create: if isSignedIn() && isUserActive();
      allow update: if isSignedIn() && isUserActive() && (
        isAdmin() || 
        (resource.data.responsibleUserId == request.auth.uid && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['responsibleUserId'])) ||
        (isManager() && get(/databases/$(database)/documents/users/$(resource.data.responsibleUserId)).data.managerId == request.auth.uid)
      );
      allow delete: if isAdmin();

      // Subcollections
      match /interactions/{id} {
        allow read, write: if isSignedIn() && isUserActive();
      }
      match /branches/{id} {
        allow read, write: if isSignedIn() && isUserActive();
      }
      match /contacts/{id} {
        allow read, write: if isSignedIn() && isUserActive();
      }
    }

    // Proposals
    match /proposals/{proposalId} {
      allow read: if isSignedIn() && isUserActive() && (
        isAdmin() || 
        resource.data.userId == request.auth.uid ||
        (isManager() && get(/databases/$(database)/documents/users/$(resource.data.userId)).data.managerId == request.auth.uid)
      );
      allow create: if isSignedIn() && isUserActive();
      allow update: if isSignedIn() && isUserActive() && (
        isAdmin() || 
        resource.data.userId == request.auth.uid ||
        (isManager() && get(/databases/$(database)/documents/users/$(resource.data.userId)).data.managerId == request.auth.uid)
      );
      allow delete: if isAdmin();
    }

    // Tickets
    match /tickets/{ticketId} {
      allow read: if isSignedIn() && isUserActive() && (
        isAdmin() || 
        resource.data.sellerId == request.auth.uid ||
        resource.data.managerId == request.auth.uid
      );
      allow create: if isSignedIn() && isUserActive() && (isAdmin() || isManager());
      allow update: if isSignedIn() && isUserActive() && (
        isAdmin() || 
        resource.data.managerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid
      );
    }

    // Commissions
    match /commissions/{id} {
      allow read: if isSignedIn() && isUserActive() && (
        isAdmin() || 
        resource.data.userId == request.auth.uid ||
        (isManager() && get(/databases/$(database)/documents/users/$(resource.data.userId)).data.managerId == request.auth.uid)
      );
      allow create: if isSignedIn() && isUserActive();
      allow write: if isAdmin();
    }

    // Audit Logs
    match /audit_logs/{id} {
      allow create: if isSignedIn() && isUserActive();
      allow read: if isSignedIn() && isUserActive();
    }

    // Segments
    match /segments/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isUserActive();
    }
  }
}
